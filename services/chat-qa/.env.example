PORT=8090                                # Port this service listens on
LANCEDB_PATH=./data/lancedb              # Path to LanceDB directory — MUST match document-ingestion LANCEDB_PATH exactly
COLLECTION_NAME=documents                # LanceDB table name — MUST match document-ingestion COLLECTION_NAME exactly
LLM_ENDPOINT_URL=http://localhost:8080/v1  # llama-server OpenAI-compatible endpoint
LLM_BACKEND=llama                        # Backend type: llama, vllm, tgi, ovms
EMBEDDING_ENDPOINT_URL=http://localhost:8001/v1  # multimodal-embedding-serving endpoint
RERANKER_ENDPOINT_URL=http://localhost:8003  # reranker service endpoint (POST /rerank)
FETCH_K=10                               # Number of documents to retrieve before reranking
LLM_MODEL_NAME=Qwen2.5-VL               # Model name passed to ChatOpenAI
