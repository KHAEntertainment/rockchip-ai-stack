LANCEDB_PATH=./data/lancedb          # Path to LanceDB directory (must match chat-qa LANCEDB_PATH)
LOCAL_STORAGE_PATH=./data/uploads    # Directory for uploaded document files
EMBEDDING_ENDPOINT_URL=http://localhost:8001/v1  # URL of multimodal-embedding-serving OpenAI-compatible endpoint
COLLECTION_NAME=documents            # LanceDB table name (must match chat-qa COLLECTION_NAME)
EMBEDDING_MODEL_NAME=Qwen/Qwen3-VL-Embedding-2B  # Embedding model name passed to OpenAIEmbeddings
MAX_CHUNK_SIZE=512                   # Token chunk size for text splitting
CHUNK_OVERLAP=50                     # Token overlap between consecutive chunks
ALLOWED_HOSTS=                       # Comma-separated list of allowed host domains for URL ingestion (supports wildcards, e.g. *.example.com)
DEFAULT_BUCKET=documents             # Default bucket name used for file storage and metadata
BATCH_SIZE=32                        # Number of chunks per embedding API call
LOCAL_STORE_PREFIX=/tmp/doc-ingestion  # Temporary directory for file processing before ingestion
