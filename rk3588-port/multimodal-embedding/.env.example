MODEL_NAME=QwenText/qwen3-vl-embedding-2b  # Default embedding model to load at startup
MODEL_DIR=./models                          # Local directory for cached model files
USE_NPU=false                               # Set true to use RKLLM/RKNN NPU (TODO: requires hardware)
NPU_CORE=NPU_CORE_0                         # RK3588 NPU core: NPU_CORE_0, NPU_CORE_1, NPU_CORE_2, NPU_CORE_0_1_2
PORT=8001                                   # Service listen port
CLIP_ONNX_PATH=./models/clip_vision.onnx   # Path to CLIP vision encoder ONNX file (for CPU fallback)
CLIP_RKNN_PATH=./models/clip_vision.rknn   # Path to CLIP vision encoder RKNN file (for NPU)
