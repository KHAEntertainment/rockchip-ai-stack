MODEL_NAME=Qwen/Qwen3-VL-Reranker-2B  # HuggingFace model ID for the reranker
MODEL_DIR=./models                      # Local directory for cached model weights
USE_NPU=false                           # Set true to use RKLLM NPU (TODO: requires hardware)
MAX_BATCH_SIZE=32                       # Maximum pairs per forward pass (tune for memory)
PORT=8003                               # Service listen port
